# AisthOS Configuration
# Copy this file to .env and fill in your values

# Required: Anthropic API key (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Claude model (default: claude-haiku-4-5-20251001)
# Options: claude-haiku-4-5-20251001, claude-sonnet-4-6-20260514, claude-opus-4-6-20260514
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Optional: TTS voice
EDGE_TTS_VOICE=en-US-AriaNeural

# Optional: Server configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8765
